<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.NoteSphere" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand colors -->
        <item name="colorPrimary">@color/ns_cyan</item>
        <item name="colorPrimaryVariant">@color/ns_deep_blue</item>
        <item name="colorOnPrimary">@color/ns_bg_dark</item>
        
        <!-- Secondary brand colors -->
        <item name="colorSecondary">@color/ns_purple</item>
        <item name="colorSecondaryVariant">@color/ns_electric_blue</item>
        <item name="colorOnSecondary">@color/white</item>
        
        <!-- Background and surface -->
        <item name="android:windowBackground">@color/ns_bg_dark</item>
        <item name="colorSurface">@color/ns_surface</item>
        <item name="colorOnSurface">@color/ns_text_primary</item>
        <item name="colorError">@color/ns_error</item>
        
        <!-- Status bar and navigation bar -->
        <item name="android:statusBarColor">@color/ns_bg_dark</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@color/ns_bg_dark</item>

        <!-- Custom attributes for styling -->
        <item name="cardCornerRadius">24dp</item>
    </style>

    <!-- Premium Card Style (Notion/Arc aesthetic) -->
    <style name="NsCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/ns_surface</item>
        <item name="cardCornerRadius">24dp</item>
        <item name="cardElevation">0dp</item>
        <item name="android:layout_marginBottom">16dp</item>
    </style>

    <!-- Glassmorphism Surface Style -->
    <style name="NsGlass" parent="">
        <item name="android:background">@drawable/bg_glass_surface</item>
    </style>

    <style name="Theme.NoteSphere.Splash" parent="Theme.NoteSphere">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>
</resources>
