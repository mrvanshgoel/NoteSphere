<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- Top App Bar -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/background"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@android:drawable/ic_menu_revert"
            app:navigationIconTint="@color/ns_text_primary" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingBottom="16dp">

            <TextView
                android:id="@+id/tvTitle"
                style="@style/Notesphere.Text.Hero"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="2"
                tools:text="Introduction to Neural Networks" />

            <TextView
                android:id="@+id/tvInfo"
                style="@style/Notesphere.Text.Caption"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_pill_surface"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:textColor="@color/ns_cyan"
                tools:text="PDF • 2.4 MB • Oct 12" />
        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="100dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- AI Action Buttons (Horizontal Scroll) -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:paddingHorizontal="20dp"
                android:paddingVertical="8dp"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSummary"
                        style="@style/Notesphere.Button.Primary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:text="📝  Summarize" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnNotes"
                        style="@style/Notesphere.Button.Ghost"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:text="📌  Study Notes" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnConcepts"
                        style="@style/Notesphere.Button.Ghost"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:text="🧠  Key Concepts" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnQuestions"
                        style="@style/Notesphere.Button.Ghost"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:text="❓  Take Quiz" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDoubt"
                        style="@style/Notesphere.Button.Ghost"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💬  Ask Doubt" />
                </LinearLayout>
            </HorizontalScrollView>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="24dp"
                android:background="@color/ns_surface" />

            <!-- Loading State -->
            <LinearLayout
                android:id="@+id/layoutLoading"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="gone">

                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:indeterminate="true"
                    app:indicatorColor="@color/ns_cyan" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Analyzing material with AI..."
                    android:textColor="@color/ns_text_secondary" />
            </LinearLayout>

            <!-- Result Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardResult"
                style="@style/Notesphere.Card.AI"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:visibility="visible"> <!-- Default visible with intro text -->

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <TextView
                            android:id="@+id/tvResultTitle"
                            style="@style/Notesphere.Text.Section"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentStart="true"
                            android:layout_centerVertical="true"
                            android:text="AI Workspace"
                            android:textColor="@color/ns_cyan" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnP2PShare"
                            style="@style/Widget.MaterialComponents.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:text="Share Link"
                            android:textColor="@color/ns_cyan"
                            app:icon="@android:drawable/ic_menu_share"
                            app:iconTint="@color/ns_cyan" />
                    </RelativeLayout>

                    <TextView
                        android:id="@+id/tvContent"
                        style="@style/Notesphere.Text.Body"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Select an AI tool from above to begin analyzing this material.\n\nYou can generate summaries, extract key concepts, or test your knowledge with an AI-generated quiz."
                        android:textColor="@color/ns_text_primary" />

                    <!-- Action Bar for Results -->
                    <LinearLayout
                        android:id="@+id/layoutResultActions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:orientation="horizontal"
                        android:visibility="gone">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnCopy"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            android:layout_weight="1"
                            android:text="Copy"
                            android:textColor="@color/ns_text_secondary"
                            app:cornerRadius="10dp"
                            app:strokeColor="@color/ns_surface" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnSavePdf"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Export PDF"
                            android:textColor="@color/ns_text_secondary"
                            app:cornerRadius="10dp"
                            app:strokeColor="@color/ns_surface" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
