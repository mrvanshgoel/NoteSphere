<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ns_bg_dark">

    <!-- ViewPager2 for pages -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPagerOnboarding"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/layoutOnboardingBottom"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Bottom controls -->
    <LinearLayout
        android:id="@+id/layoutOnboardingBottom"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="32dp"
        android:paddingHorizontal="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Dot indicators -->
        <LinearLayout
            android:id="@+id/layoutDots"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:orientation="horizontal"
            android:layout_marginBottom="32dp" />

        <!-- Next / Get Started button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOnboardingNext"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="@string/onboarding_next"
            android:textAllCaps="false"
            android:textColor="@color/ns_deep_blue"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="@color/ns_cyan"
            app:cornerRadius="16dp" />

        <!-- Skip button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOnboardingSkip"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:text="@string/onboarding_skip"
            android:textAllCaps="false"
            android:textColor="@color/ns_text_dim" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
